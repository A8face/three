# rolling z-score + 单边CUSUM
# ===================================================
class RollingCUSUMDetector:
    def __init__(self, baseline_window=ZSCORE_BASELINE_WINDOW, z_threshold=ZSCORE_THRESHOLD, k=CUSUM_K, h=CUSUM_H):
        self.baseline_window = baseline_window
        self.z_threshold = z_threshold
        self.k = k
        self.h = h
        self.G_history = None
        self.z_history = None
        self.baseline_median = None
        self.baseline_std = None
        self.event_indices = None
        self.alarm_flags = None

    def fit_transform(self, deg_rate):
        s = pd.Series(deg_rate)

        rolling_median = s.rolling(
            self.baseline_window,
            min_periods=max(60, self.baseline_window // 10)
        ).median()
        rolling_std = s.rolling(
            self.baseline_window,
            min_periods=max(60, self.baseline_window // 10)
        ).std()

        early = s.iloc[:min(len(s), self.baseline_window)]
        fallback_med = early.median()
        fallback_std = early.std()
        if not np.isfinite(fallback_std) or fallback_std <= 1e-8:
            fallback_std = max(s.std(), 1e-6)

        rolling_median = rolling_median.fillna(fallback_med)
        rolling_std = rolling_std.fillna(fallback_std).clip(lower=1e-6)

        z = (s - rolling_median) / rolling_std
        score = (z - self.z_threshold).clip(lower=0)

        G = np.zeros(len(score))
        alarm_flags = np.zeros(len(score), dtype=bool)

        for i in range(1, len(score)):
            G[i] = max(0, G[i - 1] + score.iloc[i] - self.k)
            if G[i] >= self.h:
                alarm_flags[i] = True
                G[i] = 0.0

        self.G_history = G
        self.z_history = z.values
        self.baseline_median = rolling_median.values
        self.baseline_std = rolling_std.values
        self.alarm_flags = alarm_flags
        self.event_indices = self.detect_acceleration()

        return G, z.values

    def detect_acceleration(self, G=None):
        if self.alarm_flags is None:
            return np.array([], dtype=int)
        raw_idx = np.where(self.alarm_flags)[0]
        return compress_alarm_events(raw_idx, min_gap_points=ALARM_MIN_GAP_POINTS)

