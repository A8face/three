plt.plot(time_points, G, label="CUSUM")
plt.axhline(y=change_threshold, color='r', linestyle='--', label="Threshold")
plt.xlabel('Time')
plt.ylabel('CUSUM Value')
plt.title('CUSUM Trend Detection')
plt.legend()
plt.grid(True)
plt.show()
# 假设的风险和成本函数
def calculate_risk(HI, maintenance_cost_factor=1.0):
    risk = (1 - HI) * maintenance_cost_factor  # 健康指数越低，风险越高
    return risk

def calculate_cost(HI, cost_factor=1.0):
