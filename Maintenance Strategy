            bins=bins2,
            density=True,
            alpha=0.30,
            color=colors['terminal'],
            label=f'Pseudo-life to virtual EOL ({virtual_eol:.2f})'
        )
        mu_pseudo = np.mean(pseudo_samples)
        ax4.axvline(mu_pseudo, color=colors['terminal'], linestyle='--', label=f'Pseudo mean={mu_pseudo:.2f}h')

    if (not has_failure_dist) and (not has_pseudo_dist):
