    k_hat, k_var = extrapolator.fit_local_trend(analyzer.mu)
    ax1.plot(time_points, analyzer.mu, linewidth=1.5, color=colors['kalman'],
             label='Health estimate', alpha=0.7)
    sample_points = np.linspace(0, len(time_points)-1, 8, dtype=int)
    for t in sample_points:
        if t >= 10 and t < len(time_points) - 10:
            window = slice(max(0, t-10), min(len(time_points), t+11))
            x_fit = time_points[window]
            y_fit = analyzer.mu[t] + k_hat[t] * (np.arange(len(x_fit)) - 10)
            ax1.plot(x_fit, y_fit, '--', linewidth=1.0, color=colors['trend'], alpha=0.6)
    ax1.axhline(y=MAINTENANCE_THRESHOLD, color=colors['threshold'],
                linestyle='--', linewidth=1.0, alpha=0.6, label='Maintenance threshold')
    ax1.axhline(y=FAILURE_THRESHOLD, color=colors['failure'],
                linestyle='--', linewidth=1.0, alpha=0.6, label='Failure threshold')
    ax1.set_xlabel('Time (points)', fontsize=10)
    ax1.set_ylabel('Health Index', fontsize=10)
    ax1.set_ylim(0.5, 1.0)
    ax1.grid(True, alpha=0.2, linestyle='--')
    ax1.legend(loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # (b) Slope estimation
    ax2 = fig.add_subplot(gs[0, 1])
    valid_mask = ~np.isnan(k_hat)
    valid_k = k_hat[valid_mask]
    valid_times = time_points[valid_mask]
    ax2.plot(valid_times, valid_k * 1000, linewidth=1.5, color=colors['trend'])
    ax2.axhline(y=0, color='black', linestyle='-', linewidth=0.5, alpha=0.5)
    ax2.fill_between(valid_times, valid_k * 1000, 0,
                     where=(valid_k * 1000 < 0),
                     color=colors['degrading'], alpha=0.2, label='Degradation')
    ax2.set_xlabel('Time (points)', fontsize=10)
    ax2.set_ylabel('Health change rate (‰/unit)', fontsize=10)
    ax2.grid(True, alpha=0.2, linestyle='--')
    ax2.legend(loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # (c) Time to threshold
    ax3 = fig.add_subplot(gs[1, 0])
    T_m_est = np.zeros(len(time_points))
    T_f_est = np.zeros(len(time_points))
    T_m_std = np.zeros(len(time_points))
    T_f_std = np.zeros(len(time_points))
    for t in range(len(time_points)):
        if k_hat[t] < 0:
            T_m_est[t], T_m_std[t] = extrapolator.estimate_time_to_threshold(
                analyzer.mu[t], k_hat[t], analyzer.P[t], MAINTENANCE_THRESHOLD, k_var[t])
            T_f_est[t], T_f_std[t] = extrapolator.estimate_time_to_threshold(
                analyzer.mu[t], k_hat[t], analyzer.P[t], FAILURE_THRESHOLD, k_var[t])
        else:
            T_m_est[t] = T_f_est[t] = np.inf
    finite_mask = np.isfinite(T_m_est) & np.isfinite(T_f_est)
    if np.any(finite_mask):
        line1, = ax3.plot(time_points[finite_mask], T_m_est[finite_mask],
                          linewidth=1.5, color=colors['maintenance'], label='To $\\tau_m$')
        line2, = ax3.plot(time_points[finite_mask], T_f_est[finite_mask],
                          linewidth=1.5, color=colors['failure'], label='To $\\tau_f$')
        ax3.fill_between(time_points[finite_mask],
                         T_m_est[finite_mask] - T_m_std[finite_mask],
                         T_m_est[finite_mask] + T_m_std[finite_mask],
                         alpha=0.1, color=colors['maintenance'])
        ax3.fill_between(time_points[finite_mask],
                         T_f_est[finite_mask] - T_f_std[finite_mask],
                         T_f_est[finite_mask] + T_f_std[finite_mask],
                         alpha=0.1, color=colors['failure'])
    ax3.set_xlabel('Current time (points)', fontsize=10)
    ax3.set_ylabel('Estimated time to threshold', fontsize=10)
    ax3.grid(True, alpha=0.2, linestyle='--')
    ax3.legend(loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # (d) RUL distribution
    ax4 = fig.add_subplot(gs[1, 1])
    if np.any(finite_mask):
        last_idx = np.where(finite_mask)[0][-1]
        last_T_m = T_m_est[last_idx]
        last_T_std = T_m_std[last_idx]
        if last_T_std > 0:
            x = np.linspace(max(0, last_T_m - 3*last_T_std), last_T_m + 3*last_T_std, 100)
            pdf = norm.pdf(x, last_T_m, last_T_std)
            ax4.plot(x, pdf, linewidth=1.5, color=colors['bayes'], label='Probability density')
            ax4.fill_between(x, 0, pdf, alpha=0.2, color=colors['bayes'])
            ax4.axvline(x=last_T_m, color=colors['maintenance'],
                        linestyle='--', linewidth=1.0, alpha=0.8, label=f'Mean: {last_T_m:.1f}')
            ci_low = last_T_m - 1.96 * last_T_std
            ci_high = last_T_m + 1.96 * last_T_std
            ax4.axvspan(ci_low, ci_high, alpha=0.1, color=colors['confidence'], label='95% CI')
    ax4.set_xlabel('Remaining useful life (units)', fontsize=10)
    ax4.set_ylabel('Probability density', fontsize=10)
    ax4.grid(True, alpha=0.2, linestyle='--')
    ax4.legend(loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # Subplot labels below (adjusted y positions)
    fig.text(0.25, 0.70, '(a)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.75, 0.70, '(b)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.25, 0.23, '(c)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.75, 0.23, '(d)', ha='center', va='top', fontsize=12, fontweight='normal')

    return fig


