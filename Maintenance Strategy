def compute_real_recovery(df):
    starts = df.index[df['cleaning_start']].tolist()
    vals = []
    events = []

    for idx in starts:
        if idx > 0 and idx < len(df):
            before = df.loc[idx - 1, 'health']
            after = df.loc[idx, 'health']
            delta = after - before
            events.append({
                'timestamp': df.loc[idx, 'timestamp'],
                'health_before': before,
                'health_after': after,
                'delta_health': delta,
                'cleaning_effect': df.loc[idx, 'cleaning_effect']
            })
            if delta > 0:
                vals.append(delta)

    if len(events) == 0:
        events_df = pd.DataFrame(columns=['timestamp', 'health_before', 'health_after', 'delta_health', 'cleaning_effect'])
    else:
        events_df = pd.DataFrame(events)

    return (float(np.mean(vals)) if len(vals) > 0 else 0.0), events_df

