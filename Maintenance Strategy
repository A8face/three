def main():
    print("=" * 60)
    print("REAL-DATA TURBOCHARGER HEALTH MANAGEMENT ANALYSIS")
    print("=" * 60)

    df, condition_map = load_real_data(data_path)
    df_plot = thin_for_plot(df, PLOT_MAX_POINTS)

    if USE_DYNAMIC_VIRTUAL_EOL:
        virtual_eol = estimate_virtual_eol_threshold(df, FAILURE_THRESHOLD)
    else:
        virtual_eol = max(VIRTUAL_EOL_FLOOR, FAILURE_THRESHOLD - 0.05)

    print(f"Data points: {len(df)}")
    print(f"Plot points: {len(df_plot)}")
    print(f"Time span (hours): {df['time_hours'].iloc[-1]:.2f}")
    print(f"Condition categories: {list(condition_map.keys())}")
    print(f"Virtual EOL threshold: {virtual_eol:.4f}")

    recovery_mean, events_df = compute_real_recovery(df)
    print(f"Detected cleaning starts: {df['cleaning_start'].sum()}")
    print(f"Mean real recovery from cleaning: {recovery_mean:.6f}")

    HI_obs = df['health'].values
    time_hours = df['time_hours'].values

    analyzer = BayesianHealthAnalyzer(MAINTENANCE_THRESHOLD, FAILURE_THRESHOLD, q, r)
    mu, P = analyzer.kalman_filter(HI_obs, time_hours)
    P_m, P_f = analyzer.compute_probabilities()
    P_m_s, P_f_s = analyzer.smooth_probabilities(P_m, P_f, window_points=PROB_SMOOTH_WINDOW)
    states = analyzer.determine_health_state_by_mu()

    extrapolator = TrendExtrapolator(TREND_WINDOW_POINTS)
    deg_rate = df['deg_rate_per_hour'].values

    detector = RollingCUSUMDetector(
        baseline_window=ZSCORE_BASELINE_WINDOW,
        z_threshold=ZSCORE_THRESHOLD,
        k=CUSUM_K,
        h=CUSUM_H
    )
    G, z = detector.fit_transform(deg_rate)
    acc_points = detector.detect_acceleration()

    optimizer = MaintenanceOptimizer(recovery_mean=recovery_mean)

    fig1 = create_health_state_chart(df, df_plot, analyzer, P_m_s, P_f_s, states)
    fig1.savefig(os.path.join(output_path, 'health_state_classification.png'), bbox_inches='tight')
    plt.close(fig1)

    fig2, Tm, Tf, Tm_std, k_hat, k_var, flag_m = create_trend_extrapolation_chart(
        df, df_plot, analyzer, extrapolator, virtual_eol
    )
    fig2.savefig(os.path.join(output_path, 'trend_extrapolation.png'), bbox_inches='tight')
    plt.close(fig2)

    fig3, G, z, acc_points = create_acceleration_detection_chart(df, df_plot, detector, deg_rate)
    fig3.savefig(os.path.join(output_path, 'acceleration_detection.png'), bbox_inches='tight')
    plt.close(fig3)

    fig4 = create_maintenance_optimization_chart(
        df, analyzer, optimizer, states, P_m_s, P_f_s, Tm, Tf, virtual_eol, extrapolator, k_hat
    )
    fig4.savefig(os.path.join(output_path, 'maintenance_optimization.png'), bbox_inches='tight')
    plt.close(fig4)

    fig5 = create_summary_table(df, analyzer, detector, optimizer, states, recovery_mean, virtual_eol)
    fig5.savefig(os.path.join(output_path, 'analysis_summary.png'), bbox_inches='tight')
    plt.close(fig5)

    out_df = df.copy()
    out_df['mu_estimated'] = mu
    out_df['P_variance'] = P
    out_df['P_maintenance'] = P_m
    out_df['P_failure'] = P_f
    out_df['P_maintenance_smooth'] = P_m_s
    out_df['P_failure_smooth'] = P_f_s
    out_df['health_state'] = states
    out_df['local_trend'] = k_hat
    out_df['local_degradation_rate'] = np.maximum(-k_hat, 0)
    out_df['time_to_maintenance'] = Tm
    out_df['time_to_failure'] = Tf
    out_df['rul_flag'] = flag_m
    out_df['cusum_G'] = G
    out_df['rolling_zscore'] = z
    out_df['virtual_eol_threshold'] = virtual_eol
    out_df.to_csv(os.path.join(output_path, 'detailed_results_realdata.csv'), index=False)

    if len(events_df) > 0:
        events_df.to_csv(os.path.join(output_path, 'real_cleaning_events.csv'), index=False)

    print("\nAnalysis complete.")
    print(f"Results overwritten in: {output_path}")
    print(f"Acceleration alert events detected: {len(acc_points)}")

if __name__ == "__main__":
    main()
