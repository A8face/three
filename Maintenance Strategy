    plt.subplots_adjust(hspace=0.35, bottom=0.08)

    x = df_plot['timestamp']
    plot_idx = df_plot.index.values
    cleaning_times = thin_times(df.loc[df['cleaning_start'], 'timestamp'])

    ax1 = axes[0]
    ax1.plot(x, df_plot['health'], color=colors['observed'], alpha=0.6, linewidth=0.8, label='Observed health')
    ax1.plot(x, analyzer.mu[plot_idx], color=colors['kalman'], linewidth=1.5, label='Kalman estimate')
    std = np.sqrt(np.maximum(analyzer.P[plot_idx], 1e-12))
    ax1.fill_between(
        x,
        analyzer.mu[plot_idx] - 2 * std,
        analyzer.mu[plot_idx] + 2 * std,
        color=colors['confidence'],
        alpha=0.25,
        label='95% CI'
    )
    ax1.axhline(MAINTENANCE_THRESHOLD, color=colors['threshold'], linestyle='--', label=f'Maintenance threshold ({MAINTENANCE_THRESHOLD})')
    ax1.axhline(FAILURE_THRESHOLD, color=colors['failure'], linestyle='--', label=f'Failure threshold ({FAILURE_THRESHOLD})')
    for t in cleaning_times:
        ax1.axvline(t, color=colors['cleaning'], linestyle=':', alpha=0.12, linewidth=0.8)
    ax1.set_ylabel('Health Index')
    ax1.legend(loc='upper right')
    ax1.grid(True, alpha=0.3)
    add_subcaption(ax1, '(a) Health index estimation and uncertainty')

    ax2 = axes[1]
    ax2.plot(x, P_m_smooth[plot_idx], color=colors['bayes'], label='$P(HI < \\tau_m)$')
    ax2.plot(x, P_f_smooth[plot_idx], color=colors['failure'], label='$P(HI < \\tau_f)$')
    ax2.axhline(P_m_star, color=colors['maintenance'], linestyle=':', label=f'$P_m^*={P_m_star:.3f}$')
    ax2.axhline(P_f_star, color=colors['failure'], linestyle=':', alpha=0.7, label=f'$P_f^*={P_f_star:.3f}$')
    ax2.set_ylabel('Probability')
    ax2.set_ylim(-0.02, 1.02)
    ax2.legend(loc='upper right')
    ax2.grid(True, alpha=0.3)
    add_subcaption(ax2, '(b) Probability of being below thresholds')

    ax3 = axes[2]
    state_to_num = {'H': 2, 'D': 1, 'C': 0}
    state_num = np.array([state_to_num[s] for s in np.array(states)[plot_idx]])
    ax3.step(x, state_num, where='post', color='black', linewidth=1.0)
    ax3.fill_between(x, 0, state_num, step='post', color=colors['healthy'], alpha=0.12)
