    ax1.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    ax1.legend(loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # Subplot 2: Slope estimation
    ax2 = fig.add_subplot(gs[0, 1])
    
    # Filter invalid points
    valid_mask = ~np.isnan(k_hat)
    valid_k = k_hat[valid_mask]
    valid_times = time_points[valid_mask]
    
    ax2.plot(valid_times, valid_k * 1000, linewidth=1.5, color=colors['trend'])
    ax2.axhline(y=0, color='black', linestyle='-', linewidth=0.5, alpha=0.5)
    
    # Add acceleration/deceleration areas
    ax2.fill_between(valid_times, valid_k * 1000, 0, 
                     where=(valid_k * 1000 < 0), 
                     color=colors['degrading'], alpha=0.2)
    
    ax2.set_xlabel('Time (points)', fontsize=10)
    ax2.set_ylabel('Health change rate (‰/unit)', fontsize=10)
    ax2.grid(True, alpha=0.2, linestyle='--')
    
    # 添加图例
    from matplotlib.patches import Patch
    legend_elements = [
        Patch(facecolor=colors['degrading'], alpha=0.2, label='Degradation')
    ]
    ax2.legend(handles=legend_elements, loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # Subplot 3: Time to threshold estimation
    ax3 = fig.add_subplot(gs[1, 0])
    
    T_m_est = np.zeros(len(time_points))
    T_f_est = np.zeros(len(time_points))
    T_m_std = np.zeros(len(time_points))
    T_f_std = np.zeros(len(time_points))
    
    for t in range(len(time_points)):
        if k_hat[t] < 0:
            T_m_est[t], T_m_std[t] = extrapolator.estimate_time_to_threshold(
                analyzer.mu[t], k_hat[t], analyzer.P[t], MAINTENANCE_THRESHOLD, k_var[t])
            T_f_est[t], T_f_std[t] = extrapolator.estimate_time_to_threshold(
                analyzer.mu[t], k_hat[t], analyzer.P[t], FAILURE_THRESHOLD, k_var[t])
        else:
            T_m_est[t] = T_f_est[t] = np.inf
    
    # Filter infinite values
    finite_mask = np.isfinite(T_m_est) & np.isfinite(T_f_est)
    
    if np.any(finite_mask):
        line1, = ax3.plot(time_points[finite_mask], T_m_est[finite_mask], 
                         linewidth=1.5, color=colors['maintenance'])
        line2, = ax3.plot(time_points[finite_mask], T_f_est[finite_mask], 
                         linewidth=1.5, color=colors['failure'])
        
        # Add confidence intervals
        ax3.fill_between(time_points[finite_mask], 
                         T_m_est[finite_mask] - T_m_std[finite_mask],
                         T_m_est[finite_mask] + T_m_std[finite_mask],
                         alpha=0.1, color=colors['maintenance'])
        ax3.fill_between(time_points[finite_mask], 
                         T_f_est[finite_mask] - T_f_std[finite_mask],
                         T_f_est[finite_mask] + T_f_std[finite_mask],
                         alpha=0.1, color=colors['failure'])
    
    ax3.set_xlabel('Current time (points)', fontsize=10)
    ax3.set_ylabel('Estimated time to threshold', fontsize=10)
    ax3.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    ax3.legend([line1, line2], ['To τ_m', 'To τ_f'], 
              loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # Subplot 4: Remaining useful life distribution
    ax4 = fig.add_subplot(gs[1, 1])
    
    if np.any(finite_mask):
        # Select the last time point for display
        last_idx = np.where(finite_mask)[0][-1]
        last_T_m = T_m_est[last_idx]
        last_T_std = T_m_std[last_idx]
        
        if last_T_std > 0:
            # Create probability distribution of remaining useful life
            x = np.linspace(max(0, last_T_m - 3*last_T_std), last_T_m + 3*last_T_std, 100)
            pdf = norm.pdf(x, last_T_m, last_T_std)
            
            ax4.plot(x, pdf, linewidth=1.5, color=colors['bayes'])
            ax4.fill_between(x, 0, pdf, alpha=0.2, color=colors['bayes'])
            
            # Mark mean
            ax4.axvline(x=last_T_m, color=colors['maintenance'], 
                       linestyle='--', linewidth=1.0, alpha=0.8)
            
            # Mark confidence interval
            ci_low = last_T_m - 1.96 * last_T_std
            ci_high = last_T_m + 1.96 * last_T_std
            ax4.axvspan(ci_low, ci_high, alpha=0.1, color=colors['confidence'])
    
    ax4.set_xlabel('Remaining useful life (units)', fontsize=10)
    ax4.set_ylabel('Probability density', fontsize=10)
    ax4.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    ax4.legend(['Probability density', f'Mean: {last_T_m:.1f}'], 
              loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # 添加子图标签
    fig.text(0.02, 0.98, '(a)', fontsize=12, fontweight='normal')
    fig.text(0.52, 0.98, '(b)', fontsize=12, fontweight='normal')
    fig.text(0.02, 0.48, '(c)', fontsize=12, fontweight='normal')
    fig.text(0.52, 0.48, '(d)', fontsize=12, fontweight='normal')
    
    return fig

def create_acceleration_detection_chart(analyzer, detector, time_points):
    """Create accelerated degradation detection chart"""
    fig = plt.figure(figsize=(12, 10))
    
    # 创建网格布局
    gs = plt.GridSpec(2, 2, figure=fig, hspace=0.3, wspace=0.25)
    
    # Subplot 1: Health increments
    ax1 = fig.add_subplot(gs[0, 0])
    delta_mu = np.diff(analyzer.mu, prepend=analyzer.mu[0])
    
    ax1.plot(time_points, delta_mu * 1000, linewidth=1.2, color=colors['health'])
    ax1.axhline(y=v0 * 1000, color=colors['healthy'], linestyle='--', 
                linewidth=1.0, alpha=0.7)
    ax1.axhline(y=v1 * 1000, color=colors['critical'], linestyle='--', 
                linewidth=1.0, alpha=0.7)
    
    ax1.set_xlabel('Time (points)', fontsize=10)
    ax1.set_ylabel('Health increment (‰)', fontsize=10)
    ax1.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    ax1.legend([f'Normal rate: {v0*1000:.1f}‰', f'Accelerated rate: {v1*1000:.1f}‰'], 
              loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # Subplot 2: CUSUM statistic
    ax2 = fig.add_subplot(gs[0, 1])
    G = detector.compute_cusum(delta_mu)
    acceleration_points = detector.detect_acceleration(G)
    
    line1, = ax2.plot(time_points, G, linewidth=1.5, color=colors['cusum'])
    ax2.axhline(y=h_cusum, color=colors['threshold'], linestyle='--', 
                linewidth=1.0, alpha=0.7)
    
    # Mark acceleration points
    if len(acceleration_points) > 0:
        sc = ax2.scatter(time_points[acceleration_points], G[acceleration_points], 
                        color=colors['critical'], s=30, zorder=5, alpha=0.7)
    
    ax2.set_xlabel('Time (points)', fontsize=10)
    ax2.set_ylabel('CUSUM statistic', fontsize=10)
    ax2.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    if len(acceleration_points) > 0:
        ax2.legend([line1, sc], ['CUSUM', f'Acceleration ({len(acceleration_points)})'], 
                  loc='upper left', frameon=True, framealpha=0.9, fontsize=8)
    else:
        ax2.legend([line1], ['CUSUM'], loc='upper left', 
                  frameon=True, framealpha=0.9, fontsize=8)
    
    # Subplot 3: Log-likelihood ratio
    ax3 = fig.add_subplot(gs[1, 0])
    
    # Calculate log-likelihood ratio (Equation 5.21)
    s = ((v1 - v0) / (sigma_delta**2)) * (delta_mu - (v0 + v1) / 2)
    
    ax3.plot(time_points, s, linewidth=1.2, color=colors['bayes'])
    ax3.axhline(y=0, color='black', linestyle='-', linewidth=0.5, alpha=0.5)
    
    # Mark significant points
    significant_points = np.where(np.abs(s) > 1)[0]
    if len(significant_points) > 0:
        ax3.scatter(time_points[significant_points], s[significant_points], 
                   color=colors['critical'], s=15, alpha=0.5)
    
    ax3.set_xlabel('Time (points)', fontsize=10)
    ax3.set_ylabel('Log-likelihood ratio s_t', fontsize=10)
    ax3.grid(True, alpha=0.2, linestyle='--')
    
    # Subplot 4: Detection performance analysis
    ax4 = fig.add_subplot(gs[1, 1])
    
    # Simulate detection performance for different thresholds
    thresholds = np.linspace(0.5, 5, 20)
    false_alarms = []
    detection_delays = []
    
    for thresh in thresholds:
        G_test = detector.compute_cusum(delta_mu)
        alarms = np.where(G_test >= thresh)[0]
        
        if len(alarms) > 0:
            false_alarms.append(len(alarms) / len(G_test) * 100)
            
            # Simulate detection delay (simple estimation)
            if len(acceleration_points) > 0:
                first_true = acceleration_points[0]
                first_alarm = alarms[0] if len(alarms) > 0 else len(G_test)
                delay = max(0, first_alarm - first_true)
                detection_delays.append(delay)
            else:
                detection_delays.append(0)
        else:
            false_alarms.append(0)
            detection_delays.append(len(G_test))
    
    # Plot ROC curve
    ax4_twin = ax4.twinx()
    
    line1, = ax4.plot(thresholds, false_alarms, linewidth=1.5, 
                     color=colors['failure'])
    line2, = ax4_twin.plot(thresholds, detection_delays, linewidth=1.5, 
                          color=colors['bayes'], linestyle='--')
    
    # Mark current threshold
    ax4.axvline(x=h_cusum, color=colors['threshold'], linestyle=':', 
                linewidth=1.0, alpha=0.8)
    
    ax4.set_xlabel('Detection threshold h', fontsize=10)
    ax4.set_ylabel('False alarm rate (%)', fontsize=10, color=colors['failure'])
    ax4_twin.set_ylabel('Detection delay (units)', fontsize=10, color=colors['bayes'])
    
    ax4.grid(True, alpha=0.2, linestyle='--')
    
    # 优化图例
    ax4.legend([line1, line2, f'Current: {h_cusum}'], 
              ['False alarm rate', 'Detection delay', f'Current threshold: {h_cusum}'], 
              loc='upper right', frameon=True, framealpha=0.9, fontsize=8)
    
    # 添加子图标签
    fig.text(0.02, 0.98, '(a)', fontsize=12, fontweight='normal')
    fig.text(0.52, 0.98, '(b)', fontsize=12, fontweight='normal')
    fig.text(0.02, 0.48, '(c)', fontsize=12, fontweight='normal')
    fig.text(0.52, 0.48, '(d)', fontsize=12, fontweight='normal')
    
    return fig

