# 数据读取与预处理
# ===================================================
def load_real_data(file_path):
    df = pd.read_csv(file_path)

    required_cols = ['timestamp', 'health', 'degradation', 'condition', 'cleaning_effect']
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise ValueError(f"缺少必要列: {missing}")

    df['timestamp'] = pd.to_datetime(df['timestamp'])
    df = df.sort_values('timestamp').reset_index(drop=True)
    df = df.drop_duplicates(subset=['timestamp'])
    df = df.dropna(subset=required_cols).reset_index(drop=True)

    t0 = df['timestamp'].iloc[0]
    df['time_hours'] = (df['timestamp'] - t0).dt.total_seconds() / 3600.0

    dt = df['time_hours'].diff()
    median_dt = dt.dropna().median()
    if pd.isna(median_dt) or median_dt <= 0:
        median_dt = 1.0 / 60.0
    df['dt_hours'] = dt.fillna(median_dt)
    df.loc[df['dt_hours'] <= 0, 'dt_hours'] = median_dt

    df['health_smooth'] = (
        df['health']
        .rolling(SMOOTH_WINDOW, center=True, min_periods=1)
        .mean()
    )

    local_rate = compute_local_slope_rate(
        df['time_hours'].values,
        df['health_smooth'].values,
        window_points=240,
        min_points=30
    )

    deg_rate = pd.Series(local_rate)
    deg_rate = deg_rate.replace([np.inf, -np.inf], np.nan)
    deg_rate = deg_rate.rolling(RATE_SMOOTH_WINDOW, center=True, min_periods=1).median()

    valid_deg = deg_rate.dropna()
    if len(valid_deg) > 20:
        noise_floor = np.nanpercentile(valid_deg, 35)
        upper_cap = np.nanpercentile(valid_deg, 90)
    else:
        noise_floor = 0.0
        upper_cap = np.nanmax(valid_deg) if len(valid_deg) > 0 else 0.0

    deg_rate = deg_rate.where(deg_rate >= noise_floor, 0.0)
    if np.isfinite(upper_cap) and upper_cap > 0:
        deg_rate = deg_rate.clip(lower=0.0, upper=upper_cap)
    else:
        deg_rate = deg_rate.clip(lower=0.0)

    df['deg_rate_per_hour'] = deg_rate.fillna(0.0)

    df['is_cleaning'] = df['cleaning_effect'] > 0
    df['cleaning_start'] = df['is_cleaning'] & (~df['is_cleaning'].shift(1, fill_value=False))

    cats = list(df['condition'].astype('category').cat.categories)
    mapping = {c: i for i, c in enumerate(cats)}
    df['condition_code'] = df['condition'].map(mapping)

    return df, mapping

