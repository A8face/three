def add_subcaption(ax, text):
    ax.text(
        0.5, -0.18, text,
        transform=ax.transAxes,
        ha='center', va='top',
        fontsize=10
    )

def thin_for_plot(df, max_points=PLOT_MAX_POINTS):
    if len(df) <= max_points:
        return df.copy()
    step = int(np.ceil(len(df) / max_points))
    return df.iloc[::step].copy()

def thin_times(times, max_lines=120):
    if len(times) <= max_lines:
        return times
    step = int(np.ceil(len(times) / max_lines))
    return times.iloc[::step]

def compress_alarm_events(indices, min_gap_points=ALARM_MIN_GAP_POINTS):
    if len(indices) == 0:
        return np.array([], dtype=int)
    indices = np.sort(np.asarray(indices))
    events = [indices[0]]
    for idx in indices[1:]:
        if idx - events[-1] > min_gap_points:
            events.append(idx)
    return np.array(events, dtype=int)

def estimate_virtual_eol_threshold(df, failure_threshold):
    h = df['health'].dropna().values
    if len(h) == 0:
        return max(0.68, failure_threshold - 0.05)

    qv = np.quantile(h, VIRTUAL_EOL_QUANTILE)
    virtual_eol = max(qv, VIRTUAL_EOL_FLOOR)
    virtual_eol = min(virtual_eol, failure_threshold - 0.02)
    if virtual_eol >= failure_threshold:
        virtual_eol = failure_threshold - 0.02
    return float(virtual_eol)

def get_robust_degradation_slope(k_hat, fallback=-5e-4):
    k_hat = np.asarray(k_hat)
    valid = k_hat[np.isfinite(k_hat)]

    recent = valid[-2000:] if len(valid) > 0 else np.array([])
    recent_neg = recent[recent < -MIN_ABS_SLOPE]
    if len(recent_neg) > 0:
        return float(np.median(recent_neg))

    global_neg = valid[valid < -MIN_ABS_SLOPE]
    if len(global_neg) > 0:
        return float(np.median(global_neg))

    return float(fallback)

def format_threshold_time(t, current_mu, tau):
    if current_mu <= tau:
        return 'Crossed'
    if not np.isfinite(t):
        return 'Unavailable'
    return f'{t:.2f}'

def compute_local_slope_rate(time_hours, health_values, window_points=240, min_points=30):
    n = len(health_values)
    rates = np.full(n, np.nan)

    for i in range(n):
        start = max(0, i - window_points // 2)
        end = min(n, i + window_points // 2 + 1)
        if end - start < min_points:
            continue

        t_win = time_hours[start:end]
        y_win = health_values[start:end]
        valid = np.isfinite(t_win) & np.isfinite(y_win)
        if valid.sum() < min_points:
            continue

        slope, _, _, _, _ = linregress(t_win[valid], y_win[valid])
        rates[i] = max(-slope, 0.0)

    return rates

