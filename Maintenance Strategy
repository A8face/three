class BayesianHealthAnalyzer:
    def __init__(self, tau_m=MAINTENANCE_THRESHOLD, tau_f=FAILURE_THRESHOLD, q=q, r=r):
        self.tau_m = tau_m
        self.tau_f = tau_f
        self.q = q
        self.r = r
        self.mu = None
        self.P = None

    def kalman_filter(self, HI_obs, time_hours):
        n = len(HI_obs)
        mu = np.zeros(n)
        P = np.zeros(n)

        mu[0] = HI_obs[0]
        P[0] = self.r * 10

        for t in range(1, n):
            dt = time_hours[t] - time_hours[t - 1]
            if dt <= 0:
                dt = 1e-6

            q_eff = self.q * dt
            mu_pred = mu[t - 1]
            P_pred = P[t - 1] + q_eff

            K = P_pred / (P_pred + self.r)
            mu[t] = mu_pred + K * (HI_obs[t] - mu_pred)
            P[t] = (1 - K) * P_pred

        self.mu = mu
        self.P = P
        return mu, P

    def compute_probabilities(self):
        std = np.sqrt(np.maximum(self.P, 1e-12))
        P_m = norm.cdf((self.tau_m - self.mu) / std)
        P_f = norm.cdf((self.tau_f - self.mu) / std)
        return P_m, P_f

    def smooth_probabilities(self, P_m, P_f, window_points=PROB_SMOOTH_WINDOW):
        P_m_s = pd.Series(P_m).rolling(window_points, center=True, min_periods=1).mean().values
        P_f_s = pd.Series(P_f).rolling(window_points, center=True, min_periods=1).mean().values
        return P_m_s, P_f_s

    def determine_health_state_by_mu(self):
        states = []
        for v in self.mu:
            if v > self.tau_m:
                states.append('H')
            elif v > self.tau_f:
                states.append('D')
            else:
                states.append('C')
        return states

class TrendExtrapolator:
    def __init__(self, window_points=TREND_WINDOW_POINTS):
        self.window_points = window_points

    def fit_local_trend(self, time_hours, mu_values):
        n = len(mu_values)
        k_hat = np.full(n, np.nan)
        k_var = np.full(n, np.nan)

        for i in range(n):
            start = max(0, i - self.window_points)
            end = min(n, i + self.window_points + 1)
            if end - start < 20:
                continue

            t_win = time_hours[start:end]
            y_win = mu_values[start:end]
            slope, intercept, r_value, p_value, std_err = linregress(t_win, y_win)
            k_hat[i] = slope
            k_var[i] = std_err ** 2 if np.isfinite(std_err) else np.nan

        return k_hat, k_var

    def estimate_time_to_threshold_robust(
        self, mu_t, k_t, P_t, tau, k_var,
        min_abs_slope=MIN_ABS_SLOPE,
        max_rul=MAX_RUL_HOURS
    ):
        if mu_t <= tau:
            return np.nan, np.nan, 0

        if (not np.isfinite(k_t)) or (k_t >= -min_abs_slope):
            return np.nan, np.nan, 2

        T_hat = (mu_t - tau) / (-k_t)
        if (not np.isfinite(T_hat)) or (T_hat < 0):
            return np.nan, np.nan, 2

        T_hat = min(T_hat, max_rul)

        if not np.isfinite(k_var):
            k_var = 0.0

        T_var = ((1 / (-k_t)) ** 2) * P_t + (((mu_t - tau) / (k_t ** 2)) ** 2) * k_var
        T_std = np.sqrt(max(T_var, 0.0))
        if not np.isfinite(T_std):
            T_std = np.nan

        return T_hat, T_std, 1

    def simulate_threshold_hitting_distribution(
        self,
        current_mu,
        current_P,
        recent_slopes,
        target_threshold,
        process_noise_std,
        horizon_hours=MC_HORIZON_HOURS,
        dt_hours=MC_DT_HOURS,
        n_samples=MC_SAMPLES,
        allow_start_below=False,
        fallback_slope=-5e-4
    ):
        if (current_mu <= target_threshold) and (not allow_start_below):
            return np.array([])

        recent_slopes = np.asarray(recent_slopes)
        valid_slopes = recent_slopes[np.isfinite(recent_slopes)]
        valid_slopes = valid_slopes[valid_slopes < -MIN_ABS_SLOPE]

        if len(valid_slopes) > 0:
            slope_mean = np.median(valid_slopes)
            slope_std = np.std(valid_slopes)
        else:
            slope_mean = fallback_slope
            slope_std = abs(fallback_slope) * 0.25

        if (not np.isfinite(slope_std)) or (slope_std <= 1e-8):
            slope_std = max(abs(slope_mean) * 0.2, 1e-5)

        meas_std = np.sqrt(max(current_P, 1e-10))
        proc_std = max(process_noise_std, 1e-5)

        t_grid = np.arange(0, horizon_hours + dt_hours, dt_hours)
        hits = []

        for _ in range(n_samples):
            mu0 = np.random.normal(current_mu, meas_std)
            slope = np.random.normal(slope_mean, slope_std)

            if slope >= -1e-6:
                slope = -abs(slope_mean)

            y = mu0
            hit_time = np.nan

            for t in t_grid:
                if y <= target_threshold:
                    hit_time = t
                    break
                y = y + slope * dt_hours + np.random.normal(0, proc_std)

            if not np.isnan(hit_time):
                hits.append(hit_time)

        return np.array(hits)

