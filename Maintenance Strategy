        recent_slopes=recent_slopes,
        target_threshold=virtual_eol,
        process_noise_std=process_noise_std,
        horizon_hours=MC_HORIZON_HOURS,
        dt_hours=MC_DT_HOURS,
        n_samples=MC_SAMPLES,
        allow_start_below=True,
        fallback_slope=robust_slope
    )
    pseudo_mean = np.mean(pseudo_samples) if len(pseudo_samples) > 0 else np.nan

    table_data = [
        ['Health estimate μ', f'{analyzer.mu[-1]:.4f}'],
        ['Variance P', f'{analyzer.P[-1]:.6f}'],
        ['P(HI < τm)', f'{P_m_smooth[-1]:.4f}'],
        ['P(HI < τf)', f'{P_f_smooth[-1]:.4f}'],
        ['Time to τm (h)', format_threshold_time(t_m, analyzer.mu[-1], MAINTENANCE_THRESHOLD)],
        ['Time to τf (h)', format_threshold_time(t_f, analyzer.mu[-1], FAILURE_THRESHOLD)],
        ['Pseudo-life to virtual EOL (h)', 'Unavailable' if not np.isfinite(pseudo_mean) else f'{pseudo_mean:.2f}'],
        ['Current state', current_state],
        ['Recommended decision', decision],
    ]
    table = ax4.table(cellText=table_data, colLabels=['Item', 'Value'], cellLoc='left', loc='center')
    table.auto_set_font_size(False)
    table.set_fontsize(9)
    table.scale(1.1, 1.6)
    add_subcaption(ax4, '(d) Real-time decision support information')

    return fig

