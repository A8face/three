# 维护优化
# ===================================================
class MaintenanceOptimizer:
    def __init__(self, recovery_mean=0.0):
        self.c_fuel = 600.0
        self.m_f_base = 60.0
        self.k_f = 0.3
        self.C_labor = 3000.0
        self.C_material = 2000.0
        self.C_downtime = 3000.0
        self.E_L = 1500000.0
        self.alpha = 14.0
        self.beta = 0.76
        self.recovery_mean = recovery_mean

    def fuel_penalty_cost(self, HI):
        return self.c_fuel * self.m_f_base * (1 + self.k_f * (1 - HI))

    def cleaning_cost(self):
        return self.C_labor + self.C_material + 0.2 * self.C_downtime

    def risk_cost(self, HI):
        Pf = 1 / (1 + np.exp(self.alpha * (HI - self.beta)))
        return self.E_L * Pf / 365

    def total_operational_cost(self, HI, days=1.0):
        return self.fuel_penalty_cost(HI) * days + self.risk_cost(HI) * days

    def apply_realistic_cleaning(self, HI_before):
        if self.recovery_mean <= 0:
            return HI_before
        HI_after = HI_before + self.recovery_mean
        return min(0.995, HI_after)

    def optimize_cleaning_schedule(self, time_hours, mu_sequence, horizon_hours=72):
        n = len(mu_sequence)
        if n < 2:
            return np.nan, np.nan, [], []

        rel_time = time_hours - time_hours[0]
        end_idx = np.searchsorted(rel_time, horizon_hours)
        end_idx = min(max(end_idx, 2), n)

        t_sub = rel_time[:end_idx]
        mu_sub = mu_sequence[:end_idx]

        cleaning_times = []
        cumulative_costs = []

        for i in range(1, len(mu_sub) - 1):
            cost_before = 0.0
            for j in range(1, i + 1):
                dt_h = t_sub[j] - t_sub[j - 1]
                cost_before += self.total_operational_cost(mu_sub[j - 1], dt_h / 24.0)

            HI_after = self.apply_realistic_cleaning(mu_sub[i])
            post = mu_sub[i:].copy()
            post = post - mu_sub[i] + HI_after
            post = np.minimum(post, 0.995)

            cost_after = 0.0
            for j in range(1, len(post)):
                dt_h = t_sub[i + j] - t_sub[i + j - 1]
                cost_after += self.total_operational_cost(post[j - 1], dt_h / 24.0)

            total = cost_before + cost_after + self.cleaning_cost()
            cumulative_costs.append(total)
            cleaning_times.append(t_sub[i])

        if len(cumulative_costs) == 0:
            return np.nan, np.nan, [], []

        opt_idx = int(np.argmin(cumulative_costs))
        return cleaning_times[opt_idx], cumulative_costs[opt_idx], cumulative_costs, cleaning_times

