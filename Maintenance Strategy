    gs = plt.GridSpec(2, 2, figure=fig, hspace=0.35, wspace=0.32)
    fig.subplots_adjust(bottom=0.08)

    ax1 = fig.add_subplot(gs[0, 0])
    HI_range = np.linspace(0.5, 1.0, 200)
    fuel = np.array([optimizer.fuel_penalty_cost(h) for h in HI_range])
    risk = np.array([optimizer.risk_cost(h) for h in HI_range])
    total = np.array([optimizer.total_operational_cost(h) for h in HI_range])

    ax1.plot(HI_range, fuel, color=colors['trend'], label='Fuel penalty')
    ax1.plot(HI_range, total, color=colors['maintenance'], label='Total cost')
    ax1.set_xlabel('Health Index')
    ax1.set_ylabel('Cost ($/day)')

    ax1_t = ax1.twinx()
    ax1_t.plot(HI_range, risk, color=colors['risk'], label='Risk cost', linestyle='--')
    ax1_t.set_ylabel('Risk cost ($/day)', labelpad=12)

    ax1.axvline(MAINTENANCE_THRESHOLD, color=colors['threshold'], linestyle='--')
    ax1.axvline(FAILURE_THRESHOLD, color=colors['failure'], linestyle='--')
    ax1.grid(True, alpha=0.3)
    add_subcaption(ax1, '(a) Daily operational cost components')

    ax2 = fig.add_subplot(gs[0, 1])
    opt_time, opt_cost, costs, times = optimizer.optimize_cleaning_schedule(df['time_hours'].values, analyzer.mu, horizon_hours=72)
    if len(times) > 0:
        ax2.plot(times, costs, color=colors['maintenance'], label='Cumulative cost')
        if np.isfinite(opt_time):
            ax2.scatter(opt_time, opt_cost, color=colors['critical'], s=60, label=f'Optimal {opt_time:.2f} h')
            ax2.axvline(opt_time, color=colors['threshold'], linestyle=':')
        ax2.legend(loc='upper right')
    ax2.set_xlabel('Cleaning time from current start (hours)')
    ax2.set_ylabel('Cumulative cost ($)')
    ax2.ticklabel_format(style='plain', axis='y', useOffset=False)
    ax2.grid(True, alpha=0.3)
    add_subcaption(ax2, '(b) Cleaning schedule optimization')

    ax3 = fig.add_subplot(gs[1, 0])
    current_HI = analyzer.mu[-1]
    base_cost = optimizer.total_operational_cost(current_HI, 3)
    clean_cost = optimizer.cleaning_cost()

    strategies = ['Threshold 0.88', 'Threshold 0.85', 'Cost-sensitive', 'No cleaning']
    cost_thr88 = base_cost + (clean_cost if current_HI < 0.88 else 0)
    cost_thr85 = base_cost + (clean_cost if current_HI < 0.85 else 0)
    cost_cs = base_cost + (clean_cost if P_m_smooth[-1] > P_m_star else 0)
    cost_none = base_cost + optimizer.risk_cost(current_HI) * 4.0

    vals = [cost_thr88, cost_thr85, cost_cs, cost_none]
    ax3.bar(
        strategies,
        vals,
        color=[colors['maintenance'], colors['degrading'], colors['bayes'], colors['risk']],
        alpha=0.8
    )
    ax3.set_ylabel('Estimated cost ($)')
    ax3.grid(True, alpha=0.3, axis='y')
    ax3.tick_params(axis='x', rotation=15)
    add_subcaption(ax3, '(c) Comparison of maintenance strategies')

    ax4 = fig.add_subplot(gs[1, 1])
    ax4.axis('off')

    current_state = states[-1]
    t_m = Tm[-1] if np.isfinite(Tm[-1]) else np.nan
    t_f = Tf[-1] if np.isfinite(Tf[-1]) else np.nan
    decision = 'Plan cleaning' if (current_state in ['D', 'C'] or P_m_smooth[-1] > P_m_star) else 'Continue monitoring'

    robust_slope = get_robust_degradation_slope(k_hat, fallback=-5e-4)
    recent_slopes = np.array([robust_slope])
    residual = df['health'].values - analyzer.mu
