class BayesianHealthAnalyzer:
    """Bayesian Health Analyzer - Implementation of Section 5.1 Theory"""
    
    def __init__(self, tau_m=0.85, tau_f=0.75, q=1e-4, r=0.01):
        self.tau_m = tau_m
        self.tau_f = tau_f
        self.q = q  # Process noise variance
        self.r = r  # Observation noise variance
        
        # Kalman filter state
        self.mu = None  # Health estimate
        self.P = None   # Estimation variance
        self.mu_history = []
        self.P_history = []
        
    def kalman_filter(self, HI_obs):
        """Kalman filter implementation (Equations 5.9-5.11)"""
        n = len(HI_obs)
        mu = np.zeros(n)
        P = np.zeros(n)
        
        # Initialization
        mu[0] = HI_obs[0]
        P[0] = self.r
        
        for t in range(1, n):
            # Prediction step (Equation 5.9)
            mu_pred = mu[t-1]
            P_pred = P[t-1] + self.q
            
            # Update step (Equations 5.10-5.11)
            K = P_pred / (P_pred + self.r)  # Kalman gain
            mu[t] = mu_pred + K * (HI_obs[t] - mu_pred)
            P[t] = (1 - K) * P_pred
        
        self.mu = mu
        self.P = P
        self.mu_history = mu
        self.P_history = P
        
        return mu, P
    
    def compute_probabilities(self):
        """Compute probabilities P_{m,t} and P_{f,t} (Equation 5.12)"""
        if self.mu is None or self.P is None:
            raise ValueError("Please run Kalman filter first")
        
        # Standard normal distribution function
        P_m = norm.cdf((self.tau_m - self.mu) / np.sqrt(self.P))
        P_f = norm.cdf((self.tau_f - self.mu) / np.sqrt(self.P))
        
        return P_m, P_f
    
    def smooth_probabilities(self, P_m, P_f, window_size=10):
        """Persistent online smoothing (Equation 5.14)"""
        P_m_smooth = np.convolve(P_m, np.ones(window_size)/window_size, mode='same')
        P_f_smooth = np.convolve(P_f, np.ones(window_size)/window_size, mode='same')
        
        return P_m_smooth, P_f_smooth
    
    def determine_health_state(self, P_m_smooth, P_f_smooth, P_m_star, P_f_star):
        """Determine health state (Equation 5.15)"""
        states = []
        n = len(P_m_smooth)
        
        for t in range(n):
            if P_f_smooth[t] >= P_f_star:
                states.append('C')  # Critical
            elif P_m_smooth[t] >= P_m_star:
                states.append('D')  # Degrading
            else:
                states.append('H')  # Healthy
        
        return states

class TrendExtrapolator:
    """Trend Extrapolation Analyzer - Implementation of Section 5.1.2"""
    
    def __init__(self, window_size=20):
        self.window_size = window_size
    
    def fit_local_trend(self, mu_values, window_size=None):
        """Local linear fitting (Equation 5.16)"""
        if window_size is None:
            window_size = self.window_size
        
        n = len(mu_values)
        k_hat = np.zeros(n)
        k_var = np.zeros(n)
        
        half_window = window_size // 2
        
        for t in range(n):
            # Determine window boundaries
            start = max(0, t - half_window)
            end = min(n, t + half_window + 1)
            
            if end - start < 3:  # Window too small
                k_hat[t] = 0
                k_var[t] = 0
                continue
            
            window_indices = np.arange(start, end)
            window_mu = mu_values[start:end]
            
            # Calculate slope (Equation 5.16)
            i_mean = np.mean(window_indices)
            mu_mean = np.mean(window_mu)
            
            numerator = np.sum((window_indices - i_mean) * (window_mu - mu_mean))
            denominator = np.sum((window_indices - i_mean) ** 2)
            
            if denominator > 0:
                k_hat[t] = numerator / denominator
                
                # Calculate slope variance
                residuals = window_mu - (mu_mean + k_hat[t] * (window_indices - i_mean))
                if len(residuals) > 2:
                    k_var[t] = np.var(residuals) / denominator
                else:
                    k_var[t] = 0
            else:
                k_hat[t] = 0
                k_var[t] = 0
        
        return k_hat, k_var
    
    def estimate_time_to_threshold(self, mu_t, k_t, P_t, tau, k_var=None):
        """Estimate time to reach threshold (Equations 5.17-5.19)"""
        if k_t >= 0:  # Non-negative slope, health not decreasing
            return np.inf, np.inf
        
        # Estimate remaining time (Equation 5.17)
        T_hat = (mu_t - tau) / (-k_t)
        
        # Calculate variance (Equation 5.18)
        if k_var is None:
            T_var = 0
        else:
            T_var = (1 / (-k_t))**2 * P_t + ((mu_t - tau) / (k_t**2))**2 * k_var
        
        return T_hat, np.sqrt(max(0, T_var))

class CUSUMDetector:
    """Accelerated Degradation Detector - Implementation of Equations 5.20-5.23"""
    
    def __init__(self, v0=-0.001, v1=-0.005, sigma=0.002, h=2.0):
        self.v0 = v0  # Normal degradation rate
        self.v1 = v1  # Accelerated degradation rate
        self.sigma = sigma
        self.h = h  # Detection threshold
        self.G_history = []
    
    def compute_cusum(self, delta_mu):
        """Calculate CUSUM statistic (Equations 5.21-5.22)"""
        n = len(delta_mu)
        s = np.zeros(n)
        G = np.zeros(n)
        
        # Calculate log-likelihood ratio (Equation 5.21)
        for t in range(n):
            s[t] = ((self.v1 - self.v0) / (self.sigma**2)) * \
                   (delta_mu[t] - (self.v0 + self.v1) / 2)
        
        # Cumulative sum (Equation 5.22)
        for t in range(1, n):
            G[t] = max(0, G[t-1] + s[t])
        
        self.G_history = G
        return G
    
    def detect_acceleration(self, G):
        """Detect acceleration points (Equation 5.23)"""
        acceleration_points = np.where(G >= self.h)[0]
        return acceleration_points

