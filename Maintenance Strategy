class BayesianHealthAnalyzer:
    def __init__(self, tau_m=0.85, tau_f=0.75, q=1e-4, r=0.01):
        self.tau_m = tau_m
        self.tau_f = tau_f
        self.q = q
        self.r = r
        self.mu = None
        self.P = None
        self.mu_history = []
        self.P_history = []

    def kalman_filter(self, HI_obs):
        n = len(HI_obs)
        mu = np.zeros(n)
        P = np.zeros(n)
        mu[0] = HI_obs[0]
        P[0] = self.r
        for t in range(1, n):
            mu_pred = mu[t-1]
            P_pred = P[t-1] + self.q
            K = P_pred / (P_pred + self.r)
            mu[t] = mu_pred + K * (HI_obs[t] - mu_pred)
            P[t] = (1 - K) * P_pred
        self.mu = mu
        self.P = P
        self.mu_history = mu
        self.P_history = P
        return mu, P

    def compute_probabilities(self):
        if self.mu is None or self.P is None:
            raise ValueError("Please run Kalman filter first")
        P_m = norm.cdf((self.tau_m - self.mu) / np.sqrt(self.P))
        P_f = norm.cdf((self.tau_f - self.mu) / np.sqrt(self.P))
        return P_m, P_f

    def smooth_probabilities(self, P_m, P_f, window_size=10):
        P_m_smooth = np.convolve(P_m, np.ones(window_size)/window_size, mode='same')
        P_f_smooth = np.convolve(P_f, np.ones(window_size)/window_size, mode='same')
        return P_m_smooth, P_f_smooth

    def determine_health_state(self, P_m_smooth, P_f_smooth, P_m_star, P_f_star):
        states = []
        for t in range(len(P_m_smooth)):
            if P_f_smooth[t] >= P_f_star:
                states.append('C')
            elif P_m_smooth[t] >= P_m_star:
                states.append('D')
            else:
                states.append('H')
        return states

class TrendExtrapolator:
    def __init__(self, window_size=20):
        self.window_size = window_size

    def fit_local_trend(self, mu_values, window_size=None):
        if window_size is None:
            window_size = self.window_size
        n = len(mu_values)
        k_hat = np.zeros(n)
        k_var = np.zeros(n)
        half_window = window_size // 2
        for t in range(n):
            start = max(0, t - half_window)
            end = min(n, t + half_window + 1)
            if end - start < 3:
                k_hat[t] = 0
                k_var[t] = 0
                continue
            window_indices = np.arange(start, end)
            window_mu = mu_values[start:end]
            i_mean = np.mean(window_indices)
            mu_mean = np.mean(window_mu)
            numerator = np.sum((window_indices - i_mean) * (window_mu - mu_mean))
            denominator = np.sum((window_indices - i_mean) ** 2)
            if denominator > 0:
                k_hat[t] = numerator / denominator
                residuals = window_mu - (mu_mean + k_hat[t] * (window_indices - i_mean))
                if len(residuals) > 2:
                    k_var[t] = np.var(residuals) / denominator
                else:
                    k_var[t] = 0
            else:
                k_hat[t] = 0
                k_var[t] = 0
        return k_hat, k_var

    def estimate_time_to_threshold(self, mu_t, k_t, P_t, tau, k_var=None):
        if k_t >= 0:
            return np.inf, np.inf
        T_hat = (mu_t - tau) / (-k_t)
        if k_var is None:
            T_var = 0
        else:
            T_var = (1 / (-k_t))**2 * P_t + ((mu_t - tau) / (k_t**2))**2 * k_var
        return T_hat, np.sqrt(max(0, T_var))

class CUSUMDetector:
    def __init__(self, v0=-0.001, v1=-0.005, sigma=0.002, h=2.0):
        self.v0 = v0
        self.v1 = v1
        self.sigma = sigma
        self.h = h
        self.G_history = []

    def compute_cusum(self, delta_mu):
        n = len(delta_mu)
        s = np.zeros(n)
        G = np.zeros(n)
        for t in range(n):
            s[t] = ((self.v1 - self.v0) / (self.sigma**2)) * (delta_mu[t] - (self.v0 + self.v1) / 2)
        for t in range(1, n):
            G[t] = max(0, G[t-1] + s[t])
        self.G_history = G
        return G

    def detect_acceleration(self, G):
        return np.where(G >= self.h)[0]

