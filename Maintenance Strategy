def create_acceleration_detection_chart(df, df_plot, detector, deg_rate):
    fig = plt.figure(figsize=(12, 10))
    gs = plt.GridSpec(2, 2, figure=fig, hspace=0.35, wspace=0.28)
    fig.subplots_adjust(bottom=0.08)

    x = df_plot['timestamp']
    plot_idx = df_plot.index.values

    G, z = detector.fit_transform(deg_rate)
    acc_points = detector.detect_acceleration()

    baseline_med = detector.baseline_median
    accelerated_ref = baseline_med + detector.z_threshold * detector.baseline_std

    ax1 = fig.add_subplot(gs[0, 0])
    ax1.plot(x, deg_rate[plot_idx] * 1000, color=colors['observed'])
    ax1.plot(x, baseline_med[plot_idx] * 1000, color=colors['healthy'], linestyle='--', label='Rolling normal level')
    ax1.plot(x, accelerated_ref[plot_idx] * 1000, color=colors['critical'], linestyle='--', label='Acceleration threshold')
    ax1.set_ylabel('Degradation rate (‰/hour)')
    ax1.legend(loc='upper right')
    ax1.grid(True, alpha=0.3)
    add_subcaption(ax1, '(a) Degradation rate and reference levels')

    ax2 = fig.add_subplot(gs[0, 1])
    ax2.plot(x, G[plot_idx], color=colors['cusum'], label='CUSUM')
    ax2.axhline(detector.h, color=colors['threshold'], linestyle='--', label=f'h={detector.h:.2f}')
    if len(acc_points) > 0:
        plot_alarm_idx = [i for i in acc_points if i in set(plot_idx)]
        if len(plot_alarm_idx) > 0:
            ts = df.loc[plot_alarm_idx, 'timestamp']
            ax2.scatter(ts, np.full(len(ts), detector.h), color=colors['critical'], s=20, label='Acceleration events')
    ax2.set_ylabel('CUSUM statistic')
    ax2.legend(loc='upper right')
    ax2.grid(True, alpha=0.3)
    add_subcaption(ax2, '(b) CUSUM statistic for change detection')

    ax3 = fig.add_subplot(gs[1, 0])
    ax3.plot(x, z[plot_idx], color=colors['bayes'], label='Rolling z-score')
    sig = np.where(z >= detector.z_threshold)[0]
    plot_sig = [i for i in sig if i in set(plot_idx)]
    if len(plot_sig) > 0:
        ax3.scatter(df.loc[plot_sig, 'timestamp'], z[plot_sig], color=colors['critical'], s=10, alpha=0.6, label='Significant')
    ax3.axhline(detector.z_threshold, color=colors['threshold'], linestyle='--', linewidth=0.8)
    ax3.axhline(0, color='black', linewidth=0.8)
    ax3.set_ylabel('z_t')
    ax3.legend(loc='upper right')
    ax3.grid(True, alpha=0.3)
    add_subcaption(ax3, '(c) Rolling z-score for anomaly detection')

    # 更有信息量的敏感性图：事件数 + 首次检测延迟
    ax4 = fig.add_subplot(gs[1, 1])
    thresholds = np.linspace(max(2.0, detector.z_threshold - 1.0), detector.z_threshold + 2.0, 20)
    event_counts = []
    first_delays = []

    base_events = acc_points.copy()

    for th in thresholds:
        score = np.clip(z - th, 0, None)
        G_tmp = np.zeros_like(score, dtype=float)
        alarm_tmp = np.zeros_like(score, dtype=bool)

        for i in range(1, len(score)):
            G_tmp[i] = max(0, G_tmp[i - 1] + score[i] - detector.k)
            if G_tmp[i] >= detector.h:
                alarm_tmp[i] = True
                G_tmp[i] = 0.0

        event_tmp = compress_alarm_events(np.where(alarm_tmp)[0], min_gap_points=ALARM_MIN_GAP_POINTS)
        event_counts.append(len(event_tmp))

        if len(event_tmp) > 0 and len(base_events) > 0:
            first_delays.append(max(0, event_tmp[0] - base_events[0]))
        else:
            first_delays.append(np.nan)

    ax4_t = ax4.twinx()
    ax4.plot(thresholds, event_counts, color=colors['failure'], label='Detected event count')
    ax4_t.plot(thresholds, first_delays, color=colors['bayes'], linestyle='--', label='First detection delay')
    ax4.axvline(detector.z_threshold, color=colors['threshold'], linestyle=':', label='Current z-threshold')
    ax4.set_xlabel('Detection threshold (z-score)')
    ax4.set_ylabel('Detected event count')
    ax4_t.set_ylabel('First delay (points)')
    ax4.grid(True, alpha=0.3)
    add_subcaption(ax4, '(d) Detection sensitivity to z-threshold')

    return fig, G, z, acc_points

def create_maintenance_optimization_chart(df, analyzer, optimizer, states, P_m_smooth, P_f_smooth, Tm, Tf, virtual_eol, extrapolator, k_hat):
