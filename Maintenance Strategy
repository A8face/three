    risk_costs = [optimizer.risk_cost(h) for h in HI_range]
    total_costs = [optimizer.total_operational_cost(h) for h in HI_range]
    line1, = ax1.plot(HI_range, fuel_costs, linewidth=1.5, color=colors['trend'], label='Fuel penalty')
