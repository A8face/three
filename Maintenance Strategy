    ax4.set_xlabel('')
    ax4.grid(True, alpha=0.3)
    add_subcaption(ax4, '(d) Operating condition over time')

    return fig

def create_trend_extrapolation_chart(df, df_plot, analyzer, extrapolator, virtual_eol):
    fig = plt.figure(figsize=(12, 10))
    gs = plt.GridSpec(2, 2, figure=fig, hspace=0.35, wspace=0.28)
    fig.subplots_adjust(bottom=0.08)

    time_hours = df['time_hours'].values
    x_time = df_plot['timestamp']
    plot_idx = df_plot.index.values

    k_hat, k_var = extrapolator.fit_local_trend(time_hours, analyzer.mu)

    ax1 = fig.add_subplot(gs[0, 0])
    ax1.plot(x_time, analyzer.mu[plot_idx], color=colors['kalman'], label='Kalman estimate')
    ax1.axhline(MAINTENANCE_THRESHOLD, color=colors['threshold'], linestyle='--')
    ax1.axhline(FAILURE_THRESHOLD, color=colors['failure'], linestyle='--')
    ax1.axhline(virtual_eol, color=colors['terminal'], linestyle='--', alpha=0.8)
    ax1.set_ylabel('Health Index')
    ax1.grid(True, alpha=0.3)
    add_subcaption(ax1, '(a) Local linear trend fitting')

    ax2 = fig.add_subplot(gs[0, 1])
    deg_rate_local = np.maximum(-k_hat * 1000, 0)
    if np.isfinite(deg_rate_local).any():
        upper_cap = np.nanpercentile(deg_rate_local[np.isfinite(deg_rate_local)], 85)
        if np.isfinite(upper_cap) and upper_cap > 0:
            deg_rate_local = np.clip(deg_rate_local, 0, upper_cap)
    ax2.plot(x_time, deg_rate_local[plot_idx], color=colors['trend'])
    ax2.axhline(0, color='black', linewidth=0.8)
    ax2.set_ylabel('Degradation rate (‰/hour)')
    ax2.grid(True, alpha=0.3)
    add_subcaption(ax2, '(b) Local degradation rate')

    ax3 = fig.add_subplot(gs[1, 0])
    Tm = np.full(len(df), np.nan)
    Tf = np.full(len(df), np.nan)
    Tm_std = np.full(len(df), np.nan)
    flag_m = np.full(len(df), np.nan)

    for i in range(len(df)):
        t1, s1, f1 = extrapolator.estimate_time_to_threshold_robust(
            analyzer.mu[i], k_hat[i], analyzer.P[i], MAINTENANCE_THRESHOLD, k_var[i]
        )
        t2, _, _ = extrapolator.estimate_time_to_threshold_robust(
            analyzer.mu[i], k_hat[i], analyzer.P[i], FAILURE_THRESHOLD, k_var[i]
        )
        Tm[i], Tm_std[i], flag_m[i] = t1, s1, f1
        Tf[i] = t2

    Tf_plot = Tf.copy()
    Tf_plot[analyzer.mu <= FAILURE_THRESHOLD] = np.nan

    ax3.plot(x_time, Tm[plot_idx], color=colors['maintenance'], label='To maintenance threshold')
    ax3.plot(x_time, Tf_plot[plot_idx], color=colors['failure'], label='To failure threshold (before crossing)')
    valid = np.isfinite(Tm[plot_idx]) & np.isfinite(Tm_std[plot_idx])
    if valid.any():
        ax3.fill_between(
            x_time[valid],
            Tm[plot_idx][valid] - Tm_std[plot_idx][valid],
            Tm[plot_idx][valid] + Tm_std[plot_idx][valid],
            color=colors['maintenance'],
            alpha=0.15
        )
    ax3.set_ylabel('Estimated remaining time (hours)')
    ax3.legend(loc='upper right')
    ax3.grid(True, alpha=0.3)
    add_subcaption(ax3, '(c) Estimated remaining time to decision thresholds')

    ax4 = fig.add_subplot(gs[1, 1])
    idx = len(df) - 1
    current_mu = analyzer.mu[idx]
    current_P = analyzer.P[idx]

    robust_slope = get_robust_degradation_slope(k_hat, fallback=-5e-4)
    recent_slopes = np.array([robust_slope])

    residual = df['health'].values - analyzer.mu
    process_noise_std = np.nanstd(residual[-5000:])
    if (not np.isfinite(process_noise_std)) or (process_noise_std <= 1e-6):
        process_noise_std = 0.002

    failure_samples = extrapolator.simulate_threshold_hitting_distribution(
        current_mu=current_mu,
        current_P=current_P,
        recent_slopes=recent_slopes,
        target_threshold=FAILURE_THRESHOLD,
        process_noise_std=process_noise_std,
        horizon_hours=MC_HORIZON_HOURS,
        dt_hours=MC_DT_HOURS,
        n_samples=MC_SAMPLES,
        allow_start_below=False,
        fallback_slope=robust_slope
    )

    pseudo_samples = extrapolator.simulate_threshold_hitting_distribution(
        current_mu=current_mu,
        current_P=current_P,
        recent_slopes=recent_slopes,
        target_threshold=virtual_eol,
        process_noise_std=process_noise_std,
        horizon_hours=MC_HORIZON_HOURS,
        dt_hours=MC_DT_HOURS,
        n_samples=MC_SAMPLES,
        allow_start_below=True,
        fallback_slope=robust_slope
    )

    has_failure_dist = len(failure_samples) > 0 and np.any(failure_samples > 0)
    has_pseudo_dist = len(pseudo_samples) > 0 and np.any(pseudo_samples > 0)

    if has_failure_dist:
        bins1 = np.linspace(0, max(failure_samples.max(), 1), 30)
        ax4.hist(
            failure_samples,
            bins=bins1,
            density=True,
            alpha=0.35,
            color=colors['bayes'],
            label='To failure threshold'
        )
        mu_fail = np.mean(failure_samples)
        ax4.axvline(mu_fail, color=colors['maintenance'], linestyle='--', label=f'Failure mean={mu_fail:.2f}h')
    else:
        ax4.text(
            0.5, 0.72, 'Failure-threshold crossing already occurred',
            transform=ax4.transAxes, ha='center', va='center', fontsize=10, color=colors['failure']
        )

    if has_pseudo_dist:
        bins2 = np.linspace(0, max(pseudo_samples.max(), 1), 30)
