def main():
    print("=" * 60)
    print("TURBOCHARGER HEALTH MANAGEMENT SYSTEM")
    print("=" * 60)

    try:
        # 1. Load data
        print("\n1. Loading health data...")
        health_df = pd.read_csv(health_data_path)
        health_df['timestamp'] = pd.to_datetime(health_df['timestamp'])
        health_df.set_index('timestamp', inplace=True)

        # Only resample the 'health' column to avoid non-numeric columns
        health_resampled = health_df['health'].resample('1h').mean()
        health_resampled = health_resampled.dropna()

        if health_resampled.empty:
            raise ValueError("No valid health data after resampling!")

        HI_values = health_resampled.values

        # Downsample if too long
        if len(HI_values) > 500:
            step = len(HI_values) // 200
            HI_values = HI_values[::step]
            print(f"Downsampled to {len(HI_values)} points for analysis")

        time_points = np.arange(len(HI_values))

        print(f"Analysis data points: {len(HI_values)}")
        print(f"Health index statistics:")
        print(f"  Mean: {HI_values.mean():.3f}")
        print(f"  Std: {HI_values.std():.3f}")
        print(f"  Range: {HI_values.min():.3f} - {HI_values.max():.3f}")

        # 2. Initialize analyzers
        print("\n2. Initializing analyzers...")
        analyzer = BayesianHealthAnalyzer(MAINTENANCE_THRESHOLD, FAILURE_THRESHOLD, q, r)
        extrapolator = TrendExtrapolator(L)
        detector = CUSUMDetector(v0, v1, sigma_delta, h_cusum)
        optimizer = MaintenanceOptimizer()

        # 3. Execute analysis
        print("3. Executing health analysis...")
        mu, P = analyzer.kalman_filter(HI_values)
        P_m, P_f = analyzer.compute_probabilities()
        P_m_smooth, P_f_smooth = analyzer.smooth_probabilities(P_m, P_f, N)
        states = analyzer.determine_health_state(P_m_smooth, P_f_smooth, P_m_star, P_f_star)

        print(f"  Health state distribution: H={states.count('H')}, D={states.count('D')}, C={states.count('C')}")
        print(f"  Mean health estimate: {mu.mean():.3f}")
        print(f"  Mean uncertainty: {np.mean(np.sqrt(P)):.4f}")

        # 4. Create visualizations
