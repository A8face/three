class MaintenanceOptimizer:
    def __init__(self):
        self.c_fuel = 800.0
        self.m_f_base = 10.0
        self.k_f = 0.3
        self.C_labor = 2000.0
        self.C_material = 1000.0
        self.C_downtime = 5000.0
        self.C_opportunity = 2000.0
        self.E_L = 50000.0
        self.alpha = 20.0
        self.beta = 0.7

    def fuel_penalty_cost(self, HI):
        return self.c_fuel * self.m_f_base * (1 + self.k_f * (1 - HI))

    def cleaning_cost(self, cleaning_type='online'):
        if cleaning_type == 'online':
            return self.C_labor + self.C_material + 0.1 * self.C_downtime
        else:
            return self.C_labor + self.C_material + self.C_downtime + self.C_opportunity

    def risk_cost(self, HI):
        Pf = 1 / (1 + np.exp(self.alpha * (HI - self.beta)))
        return self.E_L * Pf

    def total_operational_cost(self, HI, days=1):
        fuel_cost = self.fuel_penalty_cost(HI) * days
        risk_cost = self.risk_cost(HI) * days / 365
        return fuel_cost + risk_cost

    def optimize_cleaning_schedule(self, HI_sequence, time_horizon=30):
        n = len(HI_sequence)
        if n < time_horizon:
            time_horizon = n
        cumulative_costs = []
        cleaning_times = []
        for t_clean in range(1, time_horizon):
            HI_before = HI_sequence[:t_clean]
            HI_after = [0.95] * (time_horizon - t_clean)
            cost_before = np.sum([self.total_operational_cost(h, 1) for h in HI_before])
            cost_after = np.sum([self.total_operational_cost(h, 1) for h in HI_after])
            cleaning_cost = self.cleaning_cost()
            total_cost = cost_before + cost_after + cleaning_cost
            cumulative_costs.append(total_cost)
            cleaning_times.append(t_clean)
        if cumulative_costs:
            optimal_idx = np.argmin(cumulative_costs)
            optimal_time = cleaning_times[optimal_idx]
            optimal_cost = cumulative_costs[optimal_idx]
        else:
            optimal_time = 0
            optimal_cost = 0
        return optimal_time, optimal_cost, cumulative_costs, cleaning_times

