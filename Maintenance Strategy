    if len(significant_points) > 0:
        ax3.scatter(time_points[significant_points], s[significant_points],
                    color=colors['critical'], s=15, alpha=0.5, label='Significant')
    ax3.set_xlabel('Time (points)', fontsize=10)
    ax3.set_ylabel('Log-likelihood ratio s_t', fontsize=10)
    ax3.grid(True, alpha=0.2, linestyle='--')
    ax3.legend(loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # (d) Detection performance
    ax4 = fig.add_subplot(gs[1, 1])
    thresholds = np.linspace(0.5, 5, 20)
    false_alarms = []
    detection_delays = []
    for thresh in thresholds:
        G_test = detector.compute_cusum(delta_mu)
        alarms = np.where(G_test >= thresh)[0]
        if len(alarms) > 0:
            false_alarms.append(len(alarms) / len(G_test) * 100)
            if len(acceleration_points) > 0:
                first_true = acceleration_points[0]
                first_alarm = alarms[0] if len(alarms) > 0 else len(G_test)
                delay = max(0, first_alarm - first_true)
                detection_delays.append(delay)
            else:
                detection_delays.append(0)
        else:
            false_alarms.append(0)
            detection_delays.append(len(G_test))
    ax4_twin = ax4.twinx()
    line1, = ax4.plot(thresholds, false_alarms, linewidth=1.5, color=colors['failure'], label='False alarm rate')
    line2, = ax4_twin.plot(thresholds, detection_delays, linewidth=1.5,
                           color=colors['bayes'], linestyle='--', label='Detection delay')
    ax4.axvline(x=h_cusum, color=colors['threshold'], linestyle=':',
                linewidth=1.0, alpha=0.8, label=f'Current h={h_cusum}')
    ax4.set_xlabel('Detection threshold h', fontsize=10)
    ax4.set_ylabel('False alarm rate (%)', fontsize=10, color=colors['failure'])
    ax4_twin.set_ylabel('Detection delay (units)', fontsize=10, color=colors['bayes'])
    ax4.grid(True, alpha=0.2, linestyle='--')
    lines = [line1, line2]
    labels = ['False alarm rate', 'Detection delay']
    ax4.legend(lines, labels, loc='best', frameon=True, framealpha=0.9, fontsize=8)

    # Subplot labels below (adjusted y positions)
    fig.text(0.25, 0.70, '(a)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.75, 0.70, '(b)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.25, 0.23, '(c)', ha='center', va='top', fontsize=12, fontweight='normal')
    fig.text(0.75, 0.23, '(d)', ha='center', va='top', fontsize=12, fontweight='normal')

    return fig


def create_maintenance_optimization_chart(optimizer, HI_sequence, time_points):
